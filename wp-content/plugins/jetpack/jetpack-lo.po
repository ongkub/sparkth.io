#: jetpack_vendor/automattic/jetpack-my-jetpack/src/products/class-boost.php:175
msgid ""
"<p>To enhance the speed of your site, with this plan you will need to optimize CSS by using the Manual Critical CSS generation feature whenever you:</p>\n"
"\t\t\t\t\t\t\t\t<ul>\n"
"\t\t\t\t\t\t\t\t\t<li>Make theme changes.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>Write a new post/page.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>Edit a post/page.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>Activate, deactivate, or update plugins that impact your site layout or HTML structure.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>Change settings of plugins that impact your site layout or HTML structure.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>Upgrade your WordPress version if the new release includes core CSS changes.</li>\n"
"\t\t\t\t\t\t\t\t</ul>"
msgstr ""
"<p>а»Җаәһаә·а»Ҳаәӯа»Җаәһаәөа»ҲаәЎаә„аә§аәІаәЎа»„аә§а»ғаә«а»үа»Җаә§аәұаәҡа»„аәҠаәӮаәӯаәҮаә—а»ҲаәІаәҷ, аәӘаәіаәҘаәұаәҡа»ҒаәңаәҷаәҒаәІаәҷаәҷаәөа»үаә—а»ҲаәІаәҷаәҲаәіа»Җаәӣаәұаәҷаә•а»үаәӯаәҮаәӣаәұаәҡа»Ғаә•а»ҲаәҮ CSS а»Ӯаә”аәҚа»ғаәҠа»үаә„аәёаәҷаәӘаә»аәЎаәҡаәұаә”аәҒаәІаәҷаәӘа»үаәІаәҮ Critical CSS аә”а»үаә§аәҚаә•аә»аәҷа»ҖаәӯаәҮа»ҖаәЎаә·а»Ҳаәӯаә—а»ҲаәІаәҷ:</p>\n"
"\t\t\t\t\t\t\t\t<ul>\n"
"\t\t\t\t\t\t\t\t\t<li>аәӣа»ҲаәҪаәҷа»ҒаәӣаәҮаә—аәөаәЎ.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>аәӮаәҪаәҷа»ӮаәһаәӘ/а»ңа»үаәІа»ға»қа»Ҳ.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>а»ҒаәҒа»үа»„аәӮа»ӮаәһаәӘ/а»ңа»үаәІ.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>а»Җаәӣаәөаә”а»ғаәҠа»ү, аәӣаәҙаә”а»ғаәҠа»ү аә«аәјаә· аәӯаәұаәҡа»Җаә”аә”аәӣаәҘаәұаәҒаәӯаәҙаәҷаә—аәөа»ҲаәЎаәөаәңаә»аәҷаә•а»Қа»Ҳаә®аә№аәҡа»Ғаәҡаәҡа»Җаә§аәұаәҡа»„аәҠ аә«аәјаә· а»Ӯаә„аәҮаәӘа»үаәІаәҮ HTML.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>аәӣа»ҲаәҪаәҷаәҒаәІаәҷаә•аәұа»үаәҮаә„а»ҲаәІаәӮаәӯаәҮаәӣаәҘаәұаәҒаәӯаәҙаәҷаә—аәөа»ҲаәЎаәөаәңаә»аәҷаә•а»Қа»Ҳаә®аә№аәҡа»Ғаәҡаәҡа»Җаә§аәұаәҡа»„аәҠ аә«аәјаә· а»Ӯаә„аәҮаәӘа»үаәІаәҮ HTML.</li>\n"
"\t\t\t\t\t\t\t\t\t<li>аәӯаәұаәҡа»ҖаәҒаәЈаә”а»Җаә§аәөаәҠаәұаәҷ WordPress аәӮаәӯаәҮаә—а»ҲаәІаәҷаә«аәІаәҒаәЎаәөаәҒаәІаәҷаәӣа»ҲаәҪаәҷа»ҒаәӣаәҮ CSS аә«аәјаәұаәҒа»ғаәҷа»Җаә§аәөаәҠаәұаәҷа»ға»қа»Ҳ.</li>\n"
"\t\t\t\t\t\t\t\t</ul>"

