a95\u0acc\u0ab6\u0ab2\u0acd\u0aaf\u0acb \u0ab6\u0ac0\u0a96\u0acb \u0a9c\u0ac7 \u0aa4\u0aae\u0ac7 \u0aa4\u0ab0\u0aa4 \u0a9c \u0ab2\u0abe\u0a97\u0ac1 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb! \u0a9a\u0abe\u0ab2\u0acb \u0a85\u0aae\u0ac7 \u0aa4\u0aae\u0aa8\u0ac7 \u0aae\u0aa6\u0aa6 \u0a95\u0ab0\u0ac0\u0a8f \u0a85\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab8\u0acd\u0aaa\u0ab0\u0acd\u0aa7\u0a95\u0acb\u0aa8\u0ac7 \u0aaa\u0abe\u0a9b\u0ab3 \u0ab0\u0abe\u0a96\u0ab5\u0abe\u0aae\u0abe\u0a82 \u0aae\u0aa6\u0aa6 \u0a95\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a9f\u0ac7 \u0ab5\u0acd\u0aaf\u0ab5\u0ab9\u0abe\u0ab0\u0ac1 SEO \u0a9f\u0abf\u0aaa\u0acd\u0ab8 \u0a86\u0aaa\u0ac0\u0a8f. \u0aa4\u0aae\u0abe\u0ab0\u0ac0 SEO \u0a97\u0ac7\u0aae\u0aa8\u0ac7 \u0aae\u0ab9\u0aa4\u0acd\u0aa4\u0aae \u0aac\u0aa8\u0abe\u0ab5\u0acb! \u0a95\u0abe\u0ab0\u0aa3 \u0a95\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac1\u0a82 %s \u0ab8\u0aac\u0acd\u0ab8\u0acd\u0a95\u0acd\u0ab0\u0abf\u0aaa\u0acd\u0ab6\u0aa8 \u0aa4\u0aae\u0aa8\u0ac7 \u0aac\u0aa7\u0abe \u0a85\u0aad\u0acd\u0aaf\u0abe\u0ab8\u0a95\u0acd\u0ab0\u0aae\u0acb\u0aa8\u0ac0 \u0a85\u0aae\u0ab0\u0acd\u0aaf\u0abe\u0aa6\u0abf\u0aa4 \u0a8d\u0a95\u0acd\u0ab8\u0ac7\u0ab8 \u0a86\u0aaa\u0ac7 \u0a9b\u0ac7."],"Choosing the right type of hosting for your site is the basis of a solid Technical SEO strategy. Learn all about it in this course!":["\u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0aae\u0abe\u0a9f\u0ac7 \u0aaf\u0acb\u0a97\u0acd\u0aaf \u0aaa\u0acd\u0ab0\u0a95\u0abe\u0ab0\u0aa8\u0ac1\u0a82 \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0aaa\u0ab8\u0a82\u0aa6 \u0a95\u0ab0\u0ab5\u0ac1\u0a82 \u0a8f \u0a8f\u0a95 \u0aae\u0a9c\u0aac\u0ac2\u0aa4 \u0a9f\u0ac7\u0a95\u0aa8\u0abf\u0a95\u0ab2 SEO \u0ab5\u0acd\u0aaf\u0ac2\u0ab9\u0ab0\u0a9a\u0aa8\u0abe\u0aa8\u0acb \u0a86\u0aa7\u0abe\u0ab0 \u0a9b\u0ac7. \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82 \u0aa4\u0ac7\u0aa8\u0abe \u0ab5\u0abf\u0ab6\u0ac7 \u0aac\u0aa7\u0ac1\u0a82 \u0ab6\u0ac0\u0a96\u0acb!"],"You have to make it possible for search engines to find your site, so they can display it in the search results. We'll tell you all about how that works in this course!":["\u0aa4\u0aae\u0abe\u0ab0\u0ac7 \u0ab8\u0ab0\u0acd\u0a9a \u0a8f\u0aa8\u0acd\u0a9c\u0abf\u0aa8 \u0aae\u0abe\u0a9f\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0ab6\u0acb\u0aa7\u0ab5\u0abe\u0aa8\u0ac1\u0a82 \u0ab6\u0a95\u0acd\u0aaf \u0aac\u0aa8\u0abe\u0ab5\u0ab5\u0ac1\u0a82 \u0aaa\u0aa1\u0ab6\u0ac7, \u0a9c\u0ac7\u0aa5\u0ac0 \u0aa4\u0ac7\u0a93 \u0aa4\u0ac7\u0aa8\u0ac7 \u0ab6\u0acb\u0aa7 \u0aaa\u0ab0\u0abf\u0aa3\u0abe\u0aae\u0acb\u0aae\u0abe\u0a82 \u0aaa\u0acd\u0ab0\u0aa6\u0ab0\u0acd\u0ab6\u0abf\u0aa4 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0ac7. \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82 \u0a85\u0aae\u0ac7 \u0aa4\u0aae\u0aa8\u0ac7 \u0aa4\u0ac7 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a95\u0abe\u0ab0\u0acd\u0aaf \u0a95\u0ab0\u0ac7 \u0a9b\u0ac7 \u0aa4\u0ac7 \u0ab5\u0abf\u0ab6\u0ac7 \u0aac\u0aa7\u0ac1\u0a82 \u0a9c\u0aa3\u0abe\u0ab5\u0ac0\u0ab6\u0ac1\u0a82!"],"Are you selling in countries all over the world? In this course, you\u2019ll learn all about setting up and managing a site that targets people in different languages and locales.":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0ab5\u0abf\u0ab6\u0acd\u0ab5\u0aad\u0ab0\u0aa8\u0abe \u0aa6\u0ac7\u0ab6\u0acb\u0aae\u0abe\u0a82 \u0ab5\u0ac7\u0a9a\u0abe\u0aa3 \u0a95\u0ab0\u0ac0 \u0ab0\u0ab9\u0acd\u0aaf\u0abe \u0a9b\u0acb? \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 \u0ab5\u0abf\u0ab5\u0abf\u0aa7 \u0aad\u0abe\u0ab7\u0abe\u0a93 \u0a85\u0aa8\u0ac7 \u0ab8\u0acd\u0aa5\u0abe\u0aa8\u0acb\u0aa8\u0abe \u0ab2\u0acb\u0a95\u0acb\u0aa8\u0ac7 \u0ab2\u0a95\u0acd\u0ab7\u0acd\u0aaf \u0aac\u0aa8\u0abe\u0ab5\u0aa4\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab5\u0abe \u0a85\u0aa8\u0ac7 \u0aa4\u0ac7\u0aa8\u0ac1\u0a82 \u0ab8\u0a82\u0a9a\u0abe\u0ab2\u0aa8 \u0a95\u0ab0\u0ab5\u0abe \u0ab5\u0abf\u0ab6\u0ac7 \u0aac\u0aa7\u0ac1\u0a82 \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb."],"Do you want to take a deep dive into structured data? In this course, you'll learn the theory related to structured data in detail.":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0ab8\u0acd\u0a9f\u0acd\u0ab0\u0a95\u0acd\u0a9a\u0ab0\u0acd\u0aa1 \u0aa1\u0ac7\u0a9f\u0abe\u0aae\u0abe\u0a82 \u0a8a\u0a82\u0aa1\u0abe \u0a89\u0aa4\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a82\u0a97\u0acb \u0a9b\u0acb? \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 \u0ab8\u0acd\u0a9f\u0acd\u0ab0\u0a95\u0acd\u0a9a\u0ab0\u0acd\u0aa1 \u0aa1\u0ac7\u0a9f\u0abe \u0ab8\u0a82\u0aac\u0a82\u0aa7\u0abf\u0aa4 \u0ab8\u0abf\u0aa6\u0acd\u0aa7\u0abe\u0a82\u0aa4 \u0ab5\u0abf\u0a97\u0aa4\u0ab5\u0abe\u0ab0 \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb."],"Learn how to optimize your online shop for your customers and for search engines!":["\u0aa4\u0aae\u0abe\u0ab0\u0abe \u0a97\u0acd\u0ab0\u0abe\u0ab9\u0a95\u0acb \u0a85\u0aa8\u0ac7 \u0ab8\u0ab0\u0acd\u0a9a \u0a8f\u0aa8\u0acd\u0a9c\u0abf\u0aa8 \u0aae\u0abe\u0a9f\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0a93\u0aa8\u0ab2\u0abe\u0a88\u0aa8 \u0aa6\u0ac1\u0a95\u0abe\u0aa8\u0aa8\u0ac7 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a91\u0aaa\u0acd\u0a9f\u0abf\u0aae\u0abe\u0a87\u0a9d \u0a95\u0ab0\u0ab5\u0ac0 \u0aa4\u0ac7 \u0a9c\u0abe\u0aa3\u0acb!"],"Do you own a local business? This course will teach you how to make sure your local audience can find you in the search results and on Google Maps!":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0ab8\u0acd\u0aa5\u0abe\u0aa8\u0abf\u0a95 \u0ab5\u0acd\u0aaf\u0ab5\u0ab8\u0abe\u0aaf \u0aa7\u0ab0\u0abe\u0ab5\u0acb \u0a9b\u0acb? \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8 \u0aa4\u0aae\u0aa8\u0ac7 \u0ab6\u0ac0\u0a96\u0ab5\u0ab6\u0ac7 \u0a95\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab8\u0acd\u0aa5\u0abe\u0aa8\u0abf\u0a95 \u0aaa\u0acd\u0ab0\u0ac7\u0a95\u0acd\u0ab7\u0a95\u0acb \u0aa4\u0aae\u0aa8\u0ac7 \u0ab6\u0acb\u0aa7 \u0aaa\u0ab0\u0abf\u0aa3\u0abe\u0aae\u0acb\u0aae\u0abe\u0a82 \u0a85\u0aa8\u0ac7 Google \u0aa8\u0a95\u0ab6\u0abe \u0aaa\u0ab0 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0ab6\u0acb\u0aa7\u0ac0 \u0ab6\u0a95\u0ac7!"],"A clear site structure benefits your users and is of great importance for SEO. Still, most people seem to forget about this. Get ahead of your competition and learn how to improve your site structure!":["\u0ab8\u0acd\u0aaa\u0ab7\u0acd\u0a9f \u0ab8\u0abe\u0a87\u0a9f \u0aae\u0abe\u0ab3\u0a96\u0ac1\u0a82 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab5\u0aaa\u0ab0\u0abe\u0ab6\u0a95\u0ab0\u0acd\u0aa4\u0abe\u0a93\u0aa8\u0ac7 \u0ab2\u0abe\u0aad \u0a86\u0aaa\u0ac7 \u0a9b\u0ac7 \u0a85\u0aa8\u0ac7 SEO \u0aae\u0abe\u0a9f\u0ac7 \u0a96\u0ac2\u0aac \u0a9c \u0aae\u0ab9\u0aa4\u0acd\u0ab5\u0aaa\u0ac2\u0ab0\u0acd\u0aa3 \u0a9b\u0ac7. \u0aa4\u0ac7\u0aae \u0a9b\u0aa4\u0abe\u0a82, \u0aae\u0acb\u0a9f\u0abe\u0aad\u0abe\u0a97\u0aa8\u0abe \u0ab2\u0acb\u0a95\u0acb \u0a86 \u0ab5\u0abf\u0ab6\u0ac7 \u0aad\u0ac2\u0ab2\u0ac0 \u0a9c\u0abe\u0aaf \u0a9b\u0ac7. \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0acd\u0aaa\u0ab0\u0acd\u0aa7\u0abe\u0aae\u0abe\u0a82 \u0a86\u0a97\u0ab3 \u0ab5\u0aa7\u0acb \u0a85\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0aae\u0abe\u0ab3\u0a96\u0ac1\u0a82 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0ab8\u0ac1\u0aa7\u0abe\u0ab0\u0ab5\u0ac1\u0a82 \u0aa4\u0ac7 \u0ab6\u0ac0\u0a96\u0acb!"],"Start creating block-tastic content with the new WordPress block editor! Learn all about the block editor and what you can do with it.":["\u0aa8\u0ab5\u0abe WordPress \u0aac\u0acd\u0ab2\u0acb\u0a95 \u0a8f\u0aa1\u0abf\u0a9f\u0ab0 \u0ab8\u0abe\u0aa5\u0ac7 \u0aac\u0acd\u0ab2\u0acb\u0a95-\u0a9f\u0ac7\u0ab8\u0acd\u0a9f\u0abf\u0a95 \u0ab8\u0abe\u0aae\u0a97\u0acd\u0ab0\u0ac0 \u0aac\u0aa8\u0abe\u0ab5\u0ab5\u0abe\u0aa8\u0ac1\u0a82 \u0ab6\u0ab0\u0ac2 \u0a95\u0ab0\u0acb! \u0aac\u0acd\u0ab2\u0acb\u0a95 \u0a8f\u0aa1\u0abf\u0a9f\u0ab0 \u0ab5\u0abf\u0ab6\u0ac7 \u0a85\u0aa8\u0ac7 \u0aa4\u0aae\u0ac7 \u0aa4\u0ac7\u0aa8\u0ac0 \u0ab8\u0abe\u0aa5\u0ac7 \u0ab6\u0ac1\u0a82 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb \u0aa4\u0ac7 \u0ab5\u0abf\u0ab6\u0ac7 \u0aac\u0aa7\u0ac1\u0a82 \u0a9c\u0abe\u0aa3\u0acb."],"Do you know the essential first step of good SEO? It's keyword research. In this training, you'll learn how to research and select the keywords that will guide searchers to your pages.":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0ab8\u0abe\u0ab0\u0abe SEO \u0aae\u0abe\u0a9f\u0ac7\u0aa8\u0ac1\u0a82 \u0aaa\u0acd\u0ab0\u0aa5\u0aae \u0aaa\u0a97\u0ab2\u0ac1\u0a82 \u0a9c\u0abe\u0aa3\u0acb \u0a9b\u0acb? \u0aa4\u0ac7 \u0a95\u0ac0\u0ab5\u0ab0\u0acd\u0aa1 \u0ab8\u0a82\u0ab6\u0acb\u0aa7\u0aa8 \u0a9b\u0ac7. \u0a86 \u0aa4\u0abe\u0ab2\u0ac0\u0aae\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb \u0a95\u0ac7 \u0ab6\u0acb\u0aa7\u0a95\u0ab0\u0acd\u0aa4\u0abe\u0a93\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0aaa\u0ac3\u0ab7\u0acd\u0aa0\u0acb \u0aaa\u0ab0 \u0aae\u0abe\u0ab0\u0acd\u0a97\u0aa6\u0ab0\u0acd\u0ab6\u0aa8 \u0a86\u0aaa\u0aa4\u0abe \u0a95\u0ac0\u0ab5\u0ab0\u0acd\u0aa1\u0acd\u0ab8\u0aa8\u0ac1\u0a82 \u0ab8\u0a82\u0ab6\u0acb\u0aa7\u0aa8 \u0a85\u0aa8\u0ac7 \u0aaa\u0ab8\u0a82\u0aa6\u0a97\u0ac0 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a95\u0ab0\u0ab5\u0ac0."],"Learn how to make your site stand out from the crowd by adding structured data!":["\u0ab8\u0acd\u0a9f\u0acd\u0ab0\u0a95\u0acd\u0a9a\u0ab0\u0acd\u0aa1 \u0aa1\u0ac7\u0a9f\u0abe \u0a89\u0aae\u0ac7\u0ab0\u0ac0\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f\u0aa8\u0ac7 \u0ab2\u0acb\u0a95\u0acb\u0aa5\u0ac0 \u0a85\u0ab2\u0a97 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0aac\u0aa8\u0abe\u0ab5\u0ab5\u0ac0 \u0aa4\u0ac7 \u0ab6\u0ac0\u0a96\u0acb!"],"In this course, you'll learn how to write awesome copy that is optimized for ranking in search engines.":["\u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb \u0a95\u0ac7 \u0ab8\u0ab0\u0acd\u0a9a \u0a8f\u0aa8\u0acd\u0a9c\u0abf\u0aa8\u0aae\u0abe\u0a82 \u0ab0\u0ac7\u0aa8\u0acd\u0a95\u0abf\u0a82\u0a97 \u0aae\u0abe\u0a9f\u0ac7 \u0a91\u0aaa\u0acd\u0a9f\u0abf\u0aae\u0abe\u0a87\u0a9d \u0a95\u0ab0\u0ac7\u0ab2\u0ac0 \u0a85\u0aa6\u0acd\u0aad\u0ac1\u0aa4 \u0aa8\u0a95\u0ab2 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0ab2\u0a96\u0ab5\u0ac0."],"Do you want to set up your own WordPress site? This course will teach you the ins and outs of creating and maintaining a WordPress website!":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0aaa\u0acb\u0aa4\u0abe\u0aa8\u0ac0 WordPress \u0ab8\u0abe\u0a87\u0a9f \u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a82\u0a97\u0acb \u0a9b\u0acb? \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8 \u0aa4\u0aae\u0aa8\u0ac7 WordPress \u0ab5\u0ac7\u0aac\u0ab8\u0abe\u0a87\u0a9f \u0aac\u0aa8\u0abe\u0ab5\u0ab5\u0abe \u0a85\u0aa8\u0ac7 \u0a9c\u0abe\u0ab3\u0ab5\u0ab5\u0abe\u0aa8\u0ac0 \u0a9d\u0ac0\u0aa3\u0ab5\u0a9f\u0aad\u0ab0\u0ac0 \u0aac\u0abe\u0aac\u0aa4\u0acb \u0ab6\u0ac0\u0a96\u0ab5\u0ab6\u0ac7!"],"In this course, you'll learn practical SEO skills on every key aspect of SEO, to make your site stand out.":["\u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 SEO \u0aa8\u0abe \u0aa6\u0ab0\u0ac7\u0a95 \u0aae\u0ac1\u0a96\u0acd\u0aaf \u0aaa\u0abe\u0ab8\u0abe\u0a93 \u0aaa\u0ab0 \u0ab5\u0acd\u0aaf\u0ab5\u0ab9\u0abe\u0ab0\u0ac1 SEO \u0a95\u0acc\u0ab6\u0ab2\u0acd\u0aaf\u0acb \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb, \u0a9c\u0ac7\u0aa5\u0ac0 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0a85\u0ab2\u0a97 \u0aa6\u0ac7\u0a96\u0abe\u0aaf."],"In this course, you'll learn about how to set up and use the %1$s for WordPress plugin so it makes SEO even easier. This course is meant for users of the block editor.":["\u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0ac7 %1$s for WordPress \u0aaa\u0acd\u0ab2\u0a97\u0a87\u0aa8 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab5\u0ac1\u0a82 \u0a85\u0aa8\u0ac7 \u0aa4\u0ac7\u0aa8\u0acb \u0a89\u0aaa\u0aaf\u0acb\u0a97 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a95\u0ab0\u0ab5\u0acb \u0aa4\u0ac7 \u0ab6\u0ac0\u0a96\u0ac0 \u0ab6\u0a95\u0ab6\u0acb \u0a9c\u0ac7\u0aa5\u0ac0 \u0aa4\u0ac7 SEO \u0aa8\u0ac7 \u0ab5\u0aa7\u0ac1 \u0ab8\u0ab0\u0ab3 \u0aac\u0aa8\u0abe\u0ab5\u0ac7. \u0a86 \u0a95\u0acb\u0ab0\u0acd\u0ab8 \u0aac\u0acd\u0ab2\u0acb\u0a95 \u0a8f\u0aa1\u0abf\u0a9f\u0ab0\u0aa8\u0abe \u0ab5\u0aaa\u0ab0\u0abe\u0ab6\u0a95\u0ab0\u0acd\u0aa4\u0abe\u0a93 \u0aae\u0abe\u0a9f\u0ac7 \u0a9b\u0ac7."],"In this free course, you'll get quick wins to make your site rank higher in Google, Bing, and Yahoo.":["\u0a86 \u0aae\u0aab\u0aa4 \u0a95\u0acb\u0ab0\u0acd\u0ab8\u0aae\u0abe\u0a82, \u0aa4\u0aae\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f\u0aa8\u0ac7 Google, Bing \u0a85\u0aa8\u0ac7 Yahoo \u0aae\u0abe\u0a82 \u0a89\u0a9a\u0acd\u0a9a \u0a95\u0acd\u0ab0\u0aae\u0abe\u0a82\u0a95\u0abf\u0aa4 \u0a95\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a9f\u0ac7 \u0a9d\u0aa1\u0aaa\u0ac0 \u0a9c\u0ac0\u0aa4 \u0aae\u0ab3\u0ab6\u0ac7."],"Academy":["\u0a8f\u0a95\u0ac7\u0aa1\u0ac7\u0aae\u0ac0"],"Unlock with %1$s":["%1$s \u0ab5\u0aa1\u0ac7 \u0a85\u0aa8\u0ab2\u0ac9\u0a95 \u0a95\u0ab0\u0acb"],"(Opens in a new browser tab)":["(\u0aa8\u0ab5\u0abe \u0aac\u0acd\u0ab0\u0abe\u0a89\u0a9d\u0ab0 \u0a9f\u0ac7\u0aac\u0aae\u0abe\u0a82 \u0a96\u0ac1\u0ab2\u0ac7 \u0a9b\u0ac7)"],"Premium":["\u0aaa\u0acd\u0ab0\u0ac0\u0aae\u0abf\u0aaf\u0aae"]}},"comment":{"reference":"js\/dist\/academy.js"}}